# Use test wallets only. Never put a real funded mainnet private key here.

# RPC endpoint. For local testing, start Anvil and use:
# SEPOLIA_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=

# Required by the Foundry scripts.
PRIVATE_KEY=

# Optional. If omitted, scripts reuse PRIVATE_KEY for all roles.
ATTACKER_PRIVATE_KEY=
VICTIM_PRIVATE_KEY=

# Filled from DeployDemo output before running RunSandwichDemo.
TOKEN_X=
TOKEN_Y=
AMM_ADDRESS=

# Optional scenario parameters.
FEE_BPS=30
SLIPPAGE_BPS=100
INITIAL_LIQUIDITY_WAD=100000000000000000000000
TRADER_FUNDING_WAD=10000000000000000000000
VICTIM_IN_WAD=1000000000000000000000
ATTACKER_IN_WAD=507044774798056237000
